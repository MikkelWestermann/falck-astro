---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Falck"
  description="An AI IDE for non-technical builders who want to vibe code with confidence."
>
  <section
    class="relative overflow-hidden min-h-[100vh] flex items-center justify-center"
  >
    <div
      class="absolute inset-0 -z-10"
      style="background-image: radial-gradient(1100px circle at 10% 10%, rgba(1, 150, 108, 0.18), transparent 60%), radial-gradient(900px circle at 90% 0%, rgba(15, 23, 42, 0.12), transparent 55%);"
    >
    </div>
    <div
      class="absolute -top-24 left-[-15%] h-[420px] w-[420px] rounded-full bg-[rgb(var(--color-primary))] opacity-20 blur-[120px]"
    >
    </div>
    <div
      class="absolute bottom-[-30%] right-[-10%] h-[520px] w-[520px] rounded-full bg-emerald-400/20 blur-[140px]"
    >
    </div>

    <div class="container mx-auto px-6 py-20 text-center">
      <h1
        class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight text-slate-950 dark:text-white"
      >
        Welcome to
        <span
          class="bg-gradient-to-r from-[rgb(var(--color-primary))] via-emerald-500 to-teal-400 bg-clip-text text-transparent"
        >
          Falck
        </span>
      </h1>
      <p
        class="mt-6 text-xl text-slate-600 dark:text-slate-300 max-w-md mx-auto"
      >
        Write your prompts to get started.
      </p>
    </div>
  </section>
</Layout>
